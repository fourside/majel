    {
      "title": "Node CPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "avg(system_cpu_utilization_ratio{k8s_cluster_name=\"majel-rpi5\"}) by (state)",
          "legendFormat": "{{state}}"
        }
      ]
    },
